{"name": "prompt_layer",
"version": "0.1.0",
"description": "A Python package for tracking and analyzing prompts used in language models.",
"permissions": ["storage", "activeTab", "scripting"],
"host_permissions": ["https://claude.ai/*", "https://*.openai.com/*", "https://chatgpt.com/*", "https://api.anthropic.com/*"],
"background": {
    "service_worker": "background.js"
  },
"content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://*.openai.com/*", "https://chatgpt.com/*"],
      "js": ["content.js"]  

        }
    ],
"web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.js", "styles.css"],
      "matches": ["https://claude.ai/*", "https://*.openai.com/*"]
    }
  ],
"action": {
    "default_popup": "popup.html",
    "default_title": "Prompt Layer"
  },
"manifest_version": 3
}



